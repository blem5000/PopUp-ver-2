<Window x:Class="popup_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Komunikat z działu IT"
        Width="850"
        Height="430"
        MinWidth="850"
        MinHeight="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="True"
        Loaded="Window_Loaded">

    <Grid x:Name="mainGrid"
          Background="#F0F0F0">

        <TextBlock x:Name="title"
                   Text="Ważny komunikat z działu IT"
                   FontFamily="Segoe UI"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#6D6E70"
                   Margin="25,20,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top" />

        <Image x:Name="pictureBox1"
               Width="306"
               Height="37"
               Margin="485,20,0,0"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Stretch="Uniform"
               Source="Resources/Service_Desk.png" />

        <RichTextBox x:Name="rtb"
                     Margin="25,85,40,105"
                     FontFamily="Segoe UI"
                     FontSize="11"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="#F0F0F0"
                     VerticalScrollBarVisibility="Auto"
                     IsDocumentEnabled="False"
                     Focusable="False" />

        <Button x:Name="button"
                Content="OK"
                Width="110"
                Height="38"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,47"
                Click="Button_Click" />

    </Grid>
</Window>